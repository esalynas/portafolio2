<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Construir desde la operación | Esteban Salinas</title>

<style>
:root{
--bg:#070b11;
--panel:rgba(255,255,255,.06);
--line:rgba(255,255,255,.12);
--text:#ffffff;
--muted:#9fa7b5;
--accent:#9fd9ff;
--blur:24px;
--shadow:0 40px 80px rgba(0,0,0,.55);
--max:1300px;
}

*{
margin:0;
padding:0;
box-sizing:border-box;
scroll-behavior:smooth;
}

body{
font-family:Inter,Segoe UI,sans-serif;
background:
radial-gradient(circle at 10% 10%,rgba(116,173,255,.10),transparent 30%),
radial-gradient(circle at 90% 70%,rgba(255,255,255,.04),transparent 30%),
linear-gradient(180deg,#05080d,#0b1119,#121926);
color:var(--text);
overflow-x:hidden;
}

/* ORBS */
.orb{
position:fixed;
border-radius:50%;
filter:blur(140px);
opacity:.16;
pointer-events:none;
}
.orb1{
width:520px;height:520px;
background:#67b9ff;
top:-120px;left:-80px;
animation:float1 14s ease infinite;
}
.orb2{
width:420px;height:420px;
background:#ffffff;
right:-100px;bottom:-60px;
animation:float2 18s ease infinite;
}
@keyframes float1{50%{transform:translate(40px,60px);}}
@keyframes float2{50%{transform:translate(-50px,-80px);}}

/* GRID EFFECT */
body::before{
content:"";
position:fixed;
inset:0;
background:linear-gradient(90deg,transparent,rgba(255,255,255,.015),transparent);
background-size:250px;
animation:grid 16s linear infinite;
pointer-events:none;
}
@keyframes grid{
100%{transform:translateX(250px);}
}

/* MOUSE LIGHT */
body::after{
content:"";
position:fixed;
inset:0;
background:radial-gradient(circle at var(--x,50%) var(--y,50%), rgba(159,217,255,.08), transparent 40%);
pointer-events:none;
}

/* LAYOUT */
section{
width:min(92%,var(--max));
margin:auto;
padding:110px 0;
}

/* Ocultar sección inicialmente */
#casos { display: none; }

/* HERO */
.hero-box{
padding:60px;
border-radius:40px;
background:var(--panel);
backdrop-filter:blur(var(--blur));
border:1px solid var(--line);
box-shadow:var(--shadow);
position:relative;
overflow:hidden;
}

.badge{
display:inline-flex;
padding:10px 18px;
border-radius:999px;
background:rgba(255,255,255,.06);
border:1px solid rgba(255,255,255,.12);
color:var(--accent);
font-size:13px;
letter-spacing:2px;
text-transform:uppercase;
}

h1{
margin-top:22px;
font-size:clamp(40px, 8vw, 112px);
line-height:.92;
letter-spacing:-4px;
}

.typed{display:block;color:var(--accent);min-height:1.4em;}
.static{display:block;}

.sub{
margin-top:24px;
max-width:760px;
font-size:22px;
color:var(--muted);
line-height:1.7;
}

.flow{
margin-top:36px;
display:flex;
flex-wrap:wrap;
gap:14px;
}

.flow span{
padding:12px 18px;
background:rgba(255,255,255,.05);
border:1px solid rgba(255,255,255,.10);
border-radius:999px;
}

.cta{
margin-top:46px;
display:inline-flex;
padding:18px 32px;
border-radius:18px;
color:#000;
font-weight:700;
text-decoration:none;
background:white;
cursor: pointer;
}

/* GRID */
.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
gap:26px;
}

.card{
padding:34px;
background:var(--panel);
border:1px solid var(--line);
border-radius:28px;
cursor:pointer;
transition:.3s;
position:relative;
}

.card:hover{
transform:translateY(-10px);
border-color:#fff;
}

.kicker{
font-size:12px;
letter-spacing:2px;
color:var(--accent);
margin-bottom:18px;
}

.card h2{font-size:30px;margin-bottom:18px;}
.card p{color:var(--muted);line-height:1.8;}

.metric{
margin-top:18px;
display:flex;
justify-content:space-between;
font-weight:600;
}
.metric .value{color:var(--accent);}

/* OVERLAY */
.overlay{
position:fixed;
inset:0;
background:rgba(0,0,0,.78);
backdrop-filter:blur(10px);
display:none;
align-items:center;
justify-content:center;
z-index:999;
}

.sim{
width:min(700px,92%);
padding:40px;
border-radius:30px;
background:rgba(15,20,30,.95);
border:1px solid rgba(255,255,255,.15);
position:relative;
}

.sim-title{
color:var(--accent);
font-size:12px;
letter-spacing:2px;
margin-bottom:20px;
}

.close{
position:absolute;
top:15px;
right:20px;
cursor:pointer;
font-size:18px;
color:white;
}

.log{
font-family:monospace;
font-size:14px;
margin:6px 0;
opacity:0;
animation:fade .3s forwards;
}

@keyframes fade{
to{opacity:1;}
}

@media (max-width: 768px) {
    h1 { font-size: 40px; }
    .hero-box { padding: 40px 20px; }
}

/* ===== TARJETA MUNDIAL (NUEVA) ===== */

.game-container{
text-align:center;
}

.area-btn{
display:block;
width:100%;
padding:15px;
margin:10px 0;
background:rgba(255,255,255,.1);
border:1px solid var(--accent);
color:white;
border-radius:10px;
cursor:pointer;
transition:.25s;
}

.area-btn:hover{
transform:translateY(-3px);
background:rgba(255,255,255,.14);
}

#gameUI{
animation:fade .4s forwards;
}




</style>
</head>

<body>

<div class="orb orb1"></div>
<div class="orb orb2"></div>

<section class="hero">
<div class="hero-box">

<div class="badge">PORTAFOLIO INTERACTIVO</div>

<h1>
<span class="typed" id="typing"></span>
<span class="static">Esteban Salinas</span>
</h1>

<div class="sub">
Construyo soluciones desde datos, automatización y experiencia operativa.
</div>

<div class="flow">
<span>SQL</span>
<span>Databricks</span>
<span>Power Automate</span>
<span>Python RPA</span>
</div>

<a class="cta" onclick="mostrarSeccion()">Explorar simulaciones</a>
</div>
</section>

<section id="casos">
<div class="grid">
<div class="card" onclick="run('data')">
<div class="kicker">SIMULACIÓN 01</div>
<h2>Calidad de información</h2>
<p>SQL + Databricks + modelo Levenshtein</p>
<div class="metric">
<div>Consistency</div>
<div class="value">94%</div>
</div>
</div>

<div class="card" onclick="run('flow')">
<div class="kicker">SIMULACIÓN 02</div>
<h2>Experiencia operativa</h2>
<p>Power Automate + Teams + notificaciones</p>
<div class="metric">
<div>Time Saved</div>
<div class="value">42%</div>
</div>
</div>

<div class="card" onclick="run('rpa')">
<div class="kicker">SIMULACIÓN 03</div>
<h2>Automatización aplicada</h2>
<p>Python RPA + análisis de datos</p>
<div class="metric">
<div>Efficiency</div>
<div class="value">55%</div>
</div>
</div>

<div class="card" onclick="run('mundial')">
<div class="kicker">SIMULACIÓN 04</div>

<h2>Mundial Corporativo</h2>

<p>Simulador de desempeño por áreas</p>

<div class="metric">
<div>Performance</div>
<div class="value">LIVE</div>
</div>

</div>

<div class="card" onclick="run('powerbi')">

<div class="kicker">SIMULACIÓN 05</div>

<h2>Analítica y Reportería</h2>

<p>Power BI + KPIs + Dashboard Ejecutivo</p>

<div class="metric">
<div>Insights</div>
<div class="value">LIVE</div>
</div>

</div>

</div>
</section>

<div class="overlay" id="overlay" onclick="closeSim(event)">
<div class="sim">
<div class="close" onclick="closeSim(event)">✕</div>
<div class="sim-title" id="title"></div>
<div id="log"></div>
</div>
</div>

<script>
/* Forzar inicio al tope */
window.history.scrollRestoration = 'manual';
window.scrollTo(0, 0);

/* Mostrar sección casos */
function mostrarSeccion() {
    const s = document.getElementById('casos');
    s.style.display = 'block';
    s.scrollIntoView({ behavior: 'smooth' });
}

/* typing */
const phrases=["Construyo soluciones desde datos", "Automatizo procesos reales", "Transformo operación en sistemas", "Optimizo experiencia operativa"];
let i=0;
const typingEl = document.getElementById("typing");
setInterval(()=>{
    typingEl.innerText=phrases[i];
    i=(i+1)%phrases.length;
},4000);
typingEl.innerText = phrases[0];

/* mouse light */
document.addEventListener("mousemove",e=>{
    document.body.style.setProperty("--x",e.clientX+"px");
    document.body.style.setProperty("--y",e.clientY+"px");
});

function addLog(text){
    const el=document.createElement("div"); el.className="log";
    let icon="•";
    if(text.includes("SQL")) icon="🗄️";
    if(text.includes("Databricks")) icon="🧠";
    if(text.includes("Power")) icon="⚡";
    if(text.includes("Python")) icon="🐍";
    if(text.includes("✔")) icon="✔";
    el.innerText=`${icon} ${text}`;
    document.getElementById("log").appendChild(el);
}

function addBlock(k,v){
    const el=document.createElement("div");
    el.style.cssText=`display:flex;justify-content:space-between;padding:10px 14px;margin:6px 0;border-radius:12px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);font-family:Segoe UI;font-size:13px;`;
    el.innerHTML=`<span>${k}</span><span style="color:#9fd9ff;font-weight:600">${v}</span>`;
    document.getElementById("log").appendChild(el);
}


async function run(type){

const overlay=document.getElementById("overlay");
const title=document.getElementById("title");
const log=document.getElementById("log");

overlay.style.display="flex";
log.innerHTML="";

const wait=(ms)=>new Promise(r=>setTimeout(r,ms));

if(type==="data"){

title.innerText="🧠 DATABRICKS • SQL + LEVENSHTEIN";

addLog("[Databricks] Cluster inicializado...");
await wait(500);

addLog("[SQL] Consultando registros...");
await wait(500);

addLog("[Levenshtein] Analizando variaciones...");
await wait(700);

addBlock("Calle 50 #30-23","vs CLL 50 No 30 23");
await wait(500);

addBlock("Similarity Score","97.8%");
await wait(500);

addBlock("Data Quality","94.2% ✔");

}

if(type==="flow"){

title.innerText="⚡ POWER AUTOMATE • TEAMS FLOW";

addLog("[Power Automate] Trigger recibido...");
await wait(500);

addLog("[Validation] OK ✔");
await wait(500);

addLog("[Teams] Enviando tarjeta...");
await wait(700);

addBlock("Canal","Operations");

addBlock("Estado","Enviado ✔");

addBlock("Impacto","-42% tiempo");

}

if(type==="rpa"){

title.innerText="🐍 PYTHON RPA • AUTOMATION";

addLog("[Python] Script iniciado...");
await wait(500);

addLog("[RPA] Accediendo ERP...");
await wait(600);

addLog("[Pandas] Procesando datos...");
await wait(700);

addBlock("Registros","1,284");

addBlock("Workflows","3");

addBlock("Tiempo","18.3s");

addLog("✔ Automatización completada");

}


/* ===== NUEVA SIMULACIÓN MUNDIAL ===== */

if(type==="mundial"){

title.innerText="🏆 MUNDIAL CORPORATIVO";

log.innerHTML=`

<div class="game-container">

<p style="color:var(--muted);margin-bottom:25px;">
Gerente: Árbitro | Esteban: VAR
</p>

<div id="areaSelector">

<button class="area-btn"
onclick="jugar('Ventas')">

🇨🇴 Selección Clúster Energía Sostenible

</button>

<button class="area-btn"
onclick="jugar('Operaciones')">

🇧🇷 Selección Clúster Hábitat Sostenible 

</button>

</div>


<div id="gameUI" style="display:none">

<h3 id="areaDisplay"></h3>

<div style="font-size:40px;margin:20px 0;">

Goles:
<span id="score">0</span>

</div>

<button
class="area-btn"
onclick="disparar()">

⚽ Disparar (Resultado)

</button>

</div>

</div>

`;

}

/* ===== POWER BI ===== */

if(type==="powerbi"){

title.innerText="📊 ANALÍTICA Y REPORTERÍA • POWER BI";

log.innerHTML="";

const wait=(ms)=>new Promise(r=>setTimeout(r,ms));

addLog("[Power BI] Conectando modelo semántico...");
await wait(900);

addLog("[SQL] Consultando Data Warehouse...");
await wait(900);

addLog("[Power Query] Transformando información...");
await wait(1000);

addLog("[DAX] Calculando indicadores...");
await wait(1000);

addBlock("Ventas del mes","$ 2.487 Millones");
await wait(700);

addBlock("Cumplimiento","96.8%");
await wait(700);

addBlock("Tiempo promedio","18 min");
await wait(700);

addBlock("Procesos automatizados","41");
await wait(700);

addBlock("Usuarios activos","328");
await wait(700);

addLog("✔ Dashboard Ejecutivo generado.");
await wait(900);

addLog("📈 Actualizando visualizaciones...");
await wait(900);

log.innerHTML += `

<div style="
margin-top:25px;
padding:25px;
border-radius:20px;
background:rgba(255,255,255,.05);
border:1px solid rgba(255,255,255,.08);
">

<div style="
font-size:13px;
letter-spacing:2px;
color:#9fd9ff;
margin-bottom:20px;
">
POWER BI DASHBOARD
</div>

<div style="
display:grid;
grid-template-columns:repeat(2,1fr);
gap:18px;
">

<div>

<div style="font-size:13px;margin-bottom:8px;">
Ventas
</div>

<div style="
height:120px;
display:flex;
align-items:flex-end;
gap:8px;
">

<div style="width:20%;height:45%;background:#5cc8ff;border-radius:5px;"></div>

<div style="width:20%;height:65%;background:#5cc8ff;border-radius:5px;"></div>

<div style="width:20%;height:52%;background:#5cc8ff;border-radius:5px;"></div>

<div style="width:20%;height:88%;background:#5cc8ff;border-radius:5px;"></div>

</div>

</div>

<div>

<div style="font-size:13px;margin-bottom:8px;">
Cumplimiento
</div>

<div style="
width:130px;
height:130px;
margin:auto;
border-radius:50%;
background:
conic-gradient(#5cc8ff 0% 92%,
rgba(255,255,255,.08) 92% 100%);
display:flex;
align-items:center;
justify-content:center;
font-size:26px;
font-weight:bold;
">

92%

</div>

</div>

</div>

<div style="
margin-top:20px;
padding:12px;
background:rgba(92,200,255,.08);
border-radius:12px;
font-size:14px;
">

💡 Insight generado por IA:

<br><br>

La línea de negocio presenta un incremento del
<strong>18%</strong> respecto al periodo anterior.

</div>

</div>

`;

}




}


/* ===== LÓGICA ORIGINAL DEL MUNDIAL ===== */

let goles=0;

function jugar(area){

document.getElementById("areaSelector").style.display="none";

document.getElementById("gameUI").style.display="block";

document.getElementById("areaDisplay").innerText=
"Jugando: "+area;

goles=0;

document.getElementById("score").innerText=0;

}

function disparar(){

const chance=Math.random();

if(chance>.3){

goles++;

alert("¡GOOOL! Meta cumplida.");

}else{

alert("¡AUTOGOL! VAR detectó actividad no cumplida.");

}

document.getElementById("score").innerText=goles;

}



function closeSim(e){
    if(e.target.id==="overlay" || e.target.classList.contains("close"))
        document.getElementById("overlay").style.display="none";
}
</script>
</body>
</html>